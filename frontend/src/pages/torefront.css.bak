* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  background: #f8fafc;
  font-family: 'Tajawal', sans-serif;
}

.storefront {
  max-width: 1200px;
  margin: 0 auto;
  padding: 20px;
  direction: rtl;
}

.storefront-header {
  background: white;
  border-radius: 16px;
  padding: 16px 24px;
  margin-bottom: 20px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.store-logo {
  display: flex;
  align-items: center;
  gap: 12px;
}

.store-logo img {
  width: 50px;
  height: 50px;
  border-radius: 50%;
  object-fit: cover;
}

.store-logo span {
  font-size: 40px;
}

.store-logo h1 {
  font-size: 24px;
  color: #1e293b;
}

.store-description {
  background: white;
  padding: 12px 20px;
  border-radius: 12px;
  margin-bottom: 20px;
  color: #64748b;
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
}

.products-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 20px;
}

.product-card {
  background: white;
  border-radius: 16px;
  padding: 16px;
  text-align: center;
  box-shadow: 0 2px 8px rgba(0,0,0,0.05);
  transition: transform 0.2s;
}

.product-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 24px rgba(0,0,0,0.1);
}

.product-card img {
  width: 100%;
  height: 180px;
  object-fit: cover;
  border-radius: 12px;
}

.product-card h3 {
  margin: 12px 0 8px;
  font-size: 18px;
  font-weight: 700;
}

.price {
  font-size: 20px;
  font-weight: bold;
  color: #2c7da0;
  margin: 8px 0;
}

.stock {
  font-size: 13px;
  color: #64748b;
}

.no-products {
  text-align: center;
  padding: 40px;
  background: white;
  border-radius: 16px;
  color: #64748b;
}

.storefront-loading,
.storefront-error {
  text-align: center;
  padding: 40px;
  font-size: 18px;
  color: #64748b;
}

.storefront-error {
  color: #dc2626;
}

@media (max-width: 640px) {
  .storefront {
    padding: 12px;
  }
  .products-grid {
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 12px;
  }
  .product-card img {
    height: 140px;
  }
  .store-logo h1 {
    font-size: 18px;
  }
}
